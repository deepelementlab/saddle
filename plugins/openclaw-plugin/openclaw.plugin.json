{
  "id": "saddle-ai-openclaw",
  "name": "Saddle OpenClaw Plugin",
  "description": "Long-term memory for OpenClaw through the Saddle Memory API (saddle serve)",
  "version": "0.1.0",
  "kind": "context-engine",
  "contextEngine": true,
  "main": "./index.js",
  "configSchema": {
    "type": "object",
    "properties": {
      "baseUrl": {
        "type": "string",
        "description": "Saddle serve base URL (no trailing slash)",
        "default": "http://127.0.0.1:1995"
      },
      "userId": {
        "type": "string",
        "description": "User id for memory rows",
        "default": "saddle-user"
      },
      "groupId": {
        "type": "string",
        "description": "Group id for shared memory",
        "default": "saddle-default-group"
      },
      "topK": {
        "type": "integer",
        "description": "Maximum memories to retrieve per assemble",
        "default": 5
      },
      "memoryTypes": {
        "type": "array",
        "description": "Saddle local store uses episodic_memory only",
        "items": {
          "type": "string",
          "enum": ["episodic_memory"]
        },
        "default": ["episodic_memory"]
      },
      "retrieveMethod": {
        "type": "string",
        "description": "Ignored by Saddle (keyword-style search only); kept for config compatibility",
        "enum": ["keyword", "vector", "hybrid", "rrf", "agentic"],
        "default": "hybrid"
      }
    }
  }
}
