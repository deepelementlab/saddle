{
  "id": "saddle-openclaw-memory",
  "name": "Saddle OpenClaw Plugin",
  "description": "Context-engine based automatic memory recall and save for OpenClaw",
  "version": "0.1.0",
  "kind": "context-engine",
  "contextEngine": true,
  "main": "./index.js",
  "configSchema": {
    "type": "object",
    "properties": {
      "baseUrl": { "type": "string", "default": "http://127.0.0.1:1995" },
      "userId": { "type": "string", "default": "saddle-user" },
      "groupId": { "type": "string", "default": "openclaw-default" },
      "topK": { "type": "integer", "default": 5 }
    }
  }
}
